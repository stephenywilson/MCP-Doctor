[
  {
    "server": "filesystem",
    "tool": "read_file",
    "arguments": {
      "path": "src/index.ts"
    }
  },
  {
    "server": "filesystem",
    "tool": "write_file",
    "arguments": {
      "path": ".env",
      "content": "API_KEY=example-not-a-real-key"
    }
  },
  {
    "server": "filesystem",
    "tool": "write_file",
    "arguments": {
      "path": "package.json",
      "content": "{ \"name\": \"my-app\" }"
    }
  },
  {
    "server": "shell",
    "tool": "execute_command",
    "arguments": {
      "command": "rm -rf /tmp/build-artifacts"
    }
  },
  {
    "server": "browser",
    "tool": "http_request",
    "arguments": {
      "url": "https://api.example.com/data",
      "token": "fake_token_for_demo_only"
    }
  }
]
